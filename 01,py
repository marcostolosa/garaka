                    <th>Technique</th>
                    <th>Evasion</th>
                    <th>Confidence</th>
                    <th>Success</th>
                    <th>Duration (s)</th>
                    <th>Payload</th>
                    <th>Response</th>
                </tr>
            </thead>
            <tbody>
        """

        # Sort results by success first, then by confidence
        sorted_results = sorted(results, key=lambda x: (-x['success'], -x['confidence']))
        
        for result in sorted_results:
            success_class = "success-row" if result['success'] else "failure-row"
            success_icon = "✅" if result['success'] else "❌"
            confidence_color = "#27ae60" if result['confidence'] > 0.8 else "#e67e22" if result['confidence'] > 0.5 else "#e74c3c"
            
            html_content += f"""
                <tr class="{success_class}">
                    <td>{result['model']}</td>
                    <td>{result['intent'].replace('_', ' ').title()}</td>
                    <td>{result['technique'].replace('_', ' ').title()}</td>
                    <td>{result['evasion'].replace('_', ' ').title()}</td>
                    <td style="color: {confidence_color};">{result['confidence']:.2f}</td>
                    <td style="font-weight: bold;">{success_icon}</td>
                    <td>{result['duration']}</td>
                    <td class="payload">{result['payload'][:150]}{'...' if len(result['payload']) > 150 else ''}</td>
                    <td class="response">{result['response'][:200]}{'...' if len(result['response']) > 200 else ''}</td>
                </tr>
            """
        
        html_content += """
            </tbody>
        </table>

        <div class="footer">
            <p>GARAKA v4.9 "NIGHTSHADE" — The Ultimate Prompt Injection Test Framework</p>
            <p>Generated on {datetime.now().strftime('%Y-%m-%d %H:%M:%S')} | Created by The Red Code Collective</p>
        </div>
    </div>
</body>
</html>
        """.format(datetime=datetime.now())
        
        with open(html_path, 'w', encoding='utf-8') as f:
            f.write(html_content)
            
        logger.info(f"[+] HTML report saved to {html_path}")
        logger.info(f"[+] Complete report available at: file://{html_path}")

def main():
